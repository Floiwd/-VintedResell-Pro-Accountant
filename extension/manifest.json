{
  "manifest_version": 3,
  "name": "ResellPro Stealth Sync",
  "version": "20.0",
  "description": "Synchronisation automatique et sécurisée pour Vinted ResellPro",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.vinted.fr/*",
        "*://*.vinted.be/*",
        "*://*.vinted.it/*",
        "*://*.vinted.es/*",
        "*://*.vinted.nl/*",
        "*://*.vinted.co.uk/*",
        "*://*.vinted.de/*",
        "*://*.vinted.com/*",
        "*://*.vinted.pl/*",
        "*://*.vinted.pt/*",
        "*://*.vinted.lu/*",
        "*://*.vinted.at/*",
        "*://*.vinted.cz/*"
      ],
      "js": ["content.js"]
    }
  ]
}
