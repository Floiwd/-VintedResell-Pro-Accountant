{
  "manifest_version": 3,
  "name": "ResellPro Stealth Sync",
  "version": "15.0",
  "description": "Synchronisation automatique et sécurisée pour Vinted ResellPro",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.vinted.fr/*",
        "*://*.vinted.be/*",
        "*://*.vinted.it/*",
        "*://*.vinted.es/*",
        "*://*.vinted.nl/*"
      ],
      "js": ["content.js"]
    }
  ]
}
