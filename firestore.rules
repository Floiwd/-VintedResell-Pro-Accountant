rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Profiles
    match /profiles/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
        && incoming().organizationId is string 
        && incoming().email == request.auth.token.email
        && incoming().keys().size() == 3;
      allow update: if isOwner(userId) 
        && incoming().organizationId == existing().organizationId
        && incoming().email == existing().email
        && incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt']);
    }

    // Inventories
    match /inventories/{inventoryId} {
      function canAccessInventory() {
        return isSignedIn() && (
          inventoryId == request.auth.uid || 
          (resource != null && existing().organizationId == request.auth.uid) ||
          (request.resource != null && incoming().organizationId == request.auth.uid)
        );
      }

      allow get: if canAccessInventory();
      allow list: if isSignedIn() && resource.data.organizationId == request.auth.uid;
      
      allow create: if canAccessInventory() 
        && incoming().organizationId == request.auth.uid
        && incoming().state is map
        && incoming().updatedAt == request.time;
        
      allow update: if canAccessInventory()
        && (resource != null && existing().organizationId == request.auth.uid)
        && incoming().organizationId == existing().organizationId
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['state', 'updatedAt'])
        )
        && incoming().updatedAt == request.time;
    }
  }
}
